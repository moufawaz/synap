require 'base64'
require 'tmpdir'

# Fastlane chdirs into fastlane/ before executing any lane.
# REPO_ROOT gives us the project root regardless of that chdir.
# __dir__ is evaluated at file-load time (before any chdir happens).
REPO_ROOT = File.expand_path('..', __dir__).freeze

# Fastlane Fastfile — SYNAP
# ─────────────────────────────────────────────────────────────────────────────
# Lanes:
#   android beta   → build signed AAB → upload to Play Internal Track
#   ios beta       → build IPA → upload to TestFlight
#   ios certs      → sync/create App Store Distribution certs via match
#
# Run locally:
#   bundle exec fastlane android beta
#   bundle exec fastlane ios beta
#
# In CI the same commands are run — secrets come from env vars.
# ─────────────────────────────────────────────────────────────────────────────

default_platform(:android)

# ─────────────────────────────────────────────────────────────────────────────
# ANDROID
# ─────────────────────────────────────────────────────────────────────────────
platform :android do

  desc "Build a signed AAB and upload to Play Internal Track"
  lane :beta do
    # 1. Bump versionCode using the GITHUB_RUN_NUMBER env var if present,
    #    otherwise fall back to timestamp.
    version_code = (ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s).to_i

    # Patch versionCode directly — no plugin required
    sh("sed -i 's/versionCode [0-9]*/versionCode #{version_code}/' ../android/app/build.gradle")

    # 2. Build signed release AAB
    gradle(
      task:            'bundle',
      build_type:      'Release',
      project_dir:     'android/',
      print_command:   false,
      properties: {
        'android.injected.signing.store.file'     => ENV['ANDROID_KEYSTORE_PATH'],
        'android.injected.signing.store.password' => ENV['ANDROID_KEYSTORE_PASSWORD'],
        'android.injected.signing.key.alias'      => ENV['ANDROID_KEY_ALIAS'],
        'android.injected.signing.key.password'   => ENV['ANDROID_KEY_PASSWORD'],
      },
    )

    # 3. Upload to Play Internal Track
    supply(
      aab:             lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      track:           'internal',
      package_name:    'app.synap.fit',
      json_key_data:   ENV['GOOGLE_PLAY_JSON_KEY'],
      skip_upload_apk: true,
      release_status:  'draft',  # change to 'completed' when ready to promote
    )

    # 4. Notify (optional — remove if not using Slack)
    if ENV['SLACK_WEBHOOK_URL']&.start_with?('https://')
      slack(
        message:     "✅ SYNAP Android #{version_code} uploaded to Play Internal Track",
        slack_url:   ENV['SLACK_WEBHOOK_URL'],
        success:     true,
      )
    end
  end

end

# ─────────────────────────────────────────────────────────────────────────────
# iOS  (requires macOS runner)
# ─────────────────────────────────────────────────────────────────────────────
platform :ios do

  # Build the API key object from individual env vars.
  # We use ASC_P8_KEY_PATH (not APP_STORE_CONNECT_API_KEY_PATH) so that
  # Fastlane does NOT auto-detect and try to JSON-parse the raw .p8 file.
  def asc_api_key
    %w[
      APP_STORE_CONNECT_API_KEY_ID
      APP_STORE_CONNECT_ISSUER_ID
      ASC_P8_KEY_PATH
    ].each do |env_name|
      UI.user_error!("Missing required environment variable: #{env_name}") if ENV[env_name].to_s.strip.empty?
    end

    key_content = File.read(ENV['ASC_P8_KEY_PATH']).strip
    unless key_content.include?('-----BEGIN PRIVATE KEY-----') && key_content.include?('-----END PRIVATE KEY-----')
      UI.user_error!('APP_STORE_CONNECT_API_KEY_P8 must include the full BEGIN/END PRIVATE KEY block.')
    end

    {
      key_id:    ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id: ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key:       key_content,
      duration:  1200,
      in_house:  false,
    }
  end

  desc "Sync (or create) App Store Distribution certificates using match"
  lane :certs do
    match(
      type:                    'appstore',
      app_identifier:          'app.synap.fit',
      git_url:                 ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_TOKEN'],
      readonly:                is_ci,
      keychain_name:           'fastlane_match',
      keychain_password:       ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      api_key:                 asc_api_key,
      verbose:                 false,
    )
  end

  desc "Create certificates and profiles in match repo (run once, not in CI)"
  lane :certs_create do
    match(
      type:                    'appstore',
      app_identifier:          'app.synap.fit',
      git_url:                 ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_TOKEN'],
      readonly:                false,
      force:                   true,
      keychain_name:           'fastlane_match',
      keychain_password:       ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      api_key:                 asc_api_key,
    )
  end

  desc "Build IPA and upload to TestFlight"
  lane :beta do
    # 1. Create a fresh keychain and install certs
    create_keychain(
      name:            'fastlane_match',
      password:        ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      default_keychain: true,
      unlock:          true,
      timeout:         3600,
      lock_when_sleeps: false,
    )
    # The GitHub runner needs a signing identity with a private key. If the
    # match repo only has a certificate/profile pair without an importable
    # identity, readonly sync fails with "no local code signing identities".
    certs_create

    # 2. Bump build number
    build_number = (ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s).to_i
    increment_build_number(
      build_number: build_number,
      xcodeproj:    'ios/App/App.xcodeproj',
    )

    # 3. Explicitly configure code signing in the Xcode project.
    # match with readonly:true installs certs but does NOT update project settings.
    # update_code_signing_settings forces the project to use the match profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  'ios/App/App.xcodeproj',
      bundle_identifier:     'app.synap.fit',
      profile_name:          'match AppStore app.synap.fit',
      code_sign_identity:    'iPhone Distribution',
      team_id:               ENV['APPLE_TEAM_ID'],
    )

    # 5. Build IPA
    # sdk: 'iphoneos' tells xcodebuild to use the iOS device SDK directly.
    # This bypasses gym's automatic destination='generic/platform=iOS' which
    # fails on GitHub Actions macos-15 when Xcode 16 platform components are
    # listed as "not installed" (even though the SDK itself is available).
    build_app(
      project:           'ios/App/App.xcodeproj',
      scheme:            'App',
      configuration:     'Release',
      sdk:               'iphoneos',
      export_method:     'app-store',
      output_directory:  './build',
      output_name:       'SYNAP.ipa',
      xcargs:            "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='match AppStore app.synap.fit'",
      export_options: {
        provisioningProfiles: {
          'app.synap.fit' => 'match AppStore app.synap.fit',
        },
        signingStyle:    'manual',
        teamID:          ENV['APPLE_TEAM_ID'],
      },
      clean:             true,
    )

    # 6. Upload to TestFlight via App Store Connect API key (no password needed)
    upload_to_testflight(
      api_key:                           asc_api_key,
      ipa:                               './build/SYNAP.ipa',
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
    )

    # 5. Notify
    if ENV['SLACK_WEBHOOK_URL']&.start_with?('https://')
      slack(
        message:     "✅ SYNAP iOS build #{build_number} uploaded to TestFlight",
        slack_url:   ENV['SLACK_WEBHOOK_URL'],
        success:     true,
      )
    end
  end

  desc "Build Expo native IPA and upload to TestFlight (uses imported .p12 cert — no cert creation)"
  lane :expo_beta do
    require 'json'

    # ── 1. Validate required secrets ─────────────────────────────────────────
    %w[
      IOS_DIST_CERT_P12_BASE64
      IOS_DIST_CERT_PASSWORD
      IOS_PROVISION_PROFILE_BASE64
      APPLE_TEAM_ID
    ].each do |var|
      UI.user_error!("Missing required secret: #{var}") if ENV[var].to_s.strip.empty?
    end

    # ── 2. Create a temporary keychain ───────────────────────────────────────
    keychain_name     = 'synap_build'
    keychain_password = 'synap_build_pw'
    keychain_path     = File.expand_path("~/Library/Keychains/#{keychain_name}-db")

    create_keychain(
      name:             keychain_name,
      password:         keychain_password,
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false,
    )

    # ── 3. Decode and import the existing Distribution certificate ────────────
    # The .p12 is stored base64-encoded in the GitHub secret IOS_DIST_CERT_P12_BASE64.
    # This never calls Apple's API to create a new cert — it just installs the one you own.
    p12_path = File.join(Dir.tmpdir, 'synap_dist.p12')
    File.binwrite(p12_path, Base64.decode64(ENV['IOS_DIST_CERT_P12_BASE64']))

    import_certificate(
      certificate_path:     p12_path,
      certificate_password: ENV['IOS_DIST_CERT_PASSWORD'],
      keychain_name:        keychain_name,
      keychain_password:    keychain_password,
      log_output:           false,
    )
    UI.message('SYNAP_SIGNING: Distribution certificate imported into keychain')

    # ── 4. Decode and install the provisioning profile ────────────────────────
    # Stored base64-encoded in IOS_PROVISION_PROFILE_BASE64.
    # Use absolute paths — Fastlane chdirs into fastlane/ before running lanes.
    build_dir   = File.join(REPO_ROOT, 'build', 'profiles')
    FileUtils.mkdir_p(build_dir)
    profile_path = File.join(build_dir, 'Synap_AppStore.mobileprovision')
    File.binwrite(profile_path, Base64.decode64(ENV['IOS_PROVISION_PROFILE_BASE64']))

    # Install into ~/Library/MobileDevice/Provisioning Profiles
    profiles_dir = File.expand_path('~/Library/MobileDevice/Provisioning Profiles')
    FileUtils.mkdir_p(profiles_dir)
    FileUtils.cp(profile_path, File.join(profiles_dir, 'Synap_AppStore.mobileprovision'))

    # Extract the profile name from the decoded plist so we reference it exactly
    plist_path   = File.join(build_dir, 'Synap_AppStore.plist')
    profile_xml  = sh("security cms -D -i '#{profile_path}'", log: false)
    File.write(plist_path, profile_xml)
    profile_name = sh("/usr/libexec/PlistBuddy -c 'Print :Name' '#{plist_path}'", log: false).strip
    UI.message("SYNAP_SIGNING: Provisioning profile installed — '#{profile_name}'")

    # ── 5. Run expo prebuild + pod install ────────────────────────────────────
    # All paths are absolute so Fastlane's chdir into fastlane/ doesn't matter.
    mobile_dir = File.join(REPO_ROOT, 'apps', 'mobile')
    ios_dir    = File.join(mobile_dir, 'ios')

    UI.message('SYNAP_BUILD: Running expo prebuild --platform ios --clean …')
    sh("cd '#{mobile_dir}' && npx expo prebuild --platform ios --clean --non-interactive", log: true)

    UI.message('SYNAP_BUILD: Running pod install …')
    sh("cd '#{ios_dir}' && pod install --repo-update", log: true)

    # Xcode 26 / iOS 26 SDK rejects the fmt compile-time format path used by
    # React Native 0.81's native pods. Disabling fmt consteval keeps runtime
    # formatting behavior while avoiding the Clang 26 archive failure.
    pods_project_path = File.join(ios_dir, 'Pods', 'Pods.xcodeproj')
    UI.user_error!("Pods project not found after pod install: #{pods_project_path}") unless File.exist?(pods_project_path)
    UI.message('SYNAP_BUILD: Patching Pods project for Xcode 26 fmt compatibility')
    require 'xcodeproj'
    pods_project = Xcodeproj::Project.open(pods_project_path)
    pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
        defs = ['$(inherited)'] if defs.nil?
        defs = [defs] if defs.is_a?(String)
        defs << 'FMT_USE_CONSTEVAL=0' unless defs.include?('FMT_USE_CONSTEVAL=0')
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = defs

        cxx_flags = config.build_settings['OTHER_CPLUSPLUSFLAGS']
        cxx_flags = ['$(inherited)'] if cxx_flags.nil?
        cxx_flags = [cxx_flags] if cxx_flags.is_a?(String)
        cxx_flags << '-DFMT_USE_CONSTEVAL=0' unless cxx_flags.include?('-DFMT_USE_CONSTEVAL=0')
        config.build_settings['OTHER_CPLUSPLUSFLAGS'] = cxx_flags

        target_value = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_s
        if target_value.empty? || Gem::Version.new(target_value) < Gem::Version.new('12.0')
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
        end
      end
    end
    pods_project.save

    # fmt relocated the consteval defines between header versions: fmt <= 10 keeps
    # FMT_USE_CONSTEVAL / FMT_CONSTEVAL in core.h, fmt >= 11 moves them to base.h.
    # (Enabling the New Architecture pulled in a newer fmt, so core.h alone is no
    # longer guaranteed to exist.) The FMT_USE_CONSTEVAL=0 build-setting injection
    # above is the primary fix; these header rewrites are belt-and-suspenders, so
    # patch whichever headers are present and don't fail the build when one isn't.
    fmt_include_dir = File.join(ios_dir, 'Pods', 'fmt', 'include', 'fmt')
    consteval_headers = ['core.h', 'base.h']
      .map { |name| File.join(fmt_include_dir, name) }
      .select { |path| File.exist?(path) }

    if consteval_headers.empty?
      UI.important("SYNAP_BUILD: No fmt consteval header (core.h/base.h) found under #{fmt_include_dir} — relying on FMT_USE_CONSTEVAL=0 build setting only")
    else
      consteval_headers.each do |header|
        File.chmod(0o644, header)
        contents = File.read(header)
        contents = contents.gsub(/#(\s*)define FMT_USE_CONSTEVAL 1/, '#\1define FMT_USE_CONSTEVAL 0')
        contents = contents.gsub(/#(\s*)define FMT_CONSTEVAL consteval/, '#\1define FMT_CONSTEVAL')
        File.write(header, contents)
        UI.message("SYNAP_BUILD: Patched fmt #{File.basename(header)} to disable consteval for Xcode 26")
      end
    end

    fmt_format_inl_header = File.join(fmt_include_dir, 'format-inl.h')
    if File.exist?(fmt_format_inl_header)
      File.chmod(0o644, fmt_format_inl_header)
      fmt_format_inl = File.read(fmt_format_inl_header)
      fmt_format_inl = fmt_format_inl.gsub('FMT_STRING(', 'fmt::runtime(')
      File.write(fmt_format_inl_header, fmt_format_inl)
      UI.message('SYNAP_BUILD: Patched fmt format-inl.h to avoid Xcode 26 consteval FMT_STRING errors')
    else
      UI.message('SYNAP_BUILD: fmt format-inl.h not present — skipping (consteval disabled via build settings)')
    end

    # ── 6. Find the CocoaPods workspace (created by pod install) ─────────────
    # After pod install, build targets live in the .xcworkspace — using the
    # bare .xcodeproj would miss all pod framework links and fail at link time.
    workspace_path = Dir[File.join(ios_dir, '*.xcworkspace')].first
    project_path   = Dir[File.join(ios_dir, '*.xcodeproj')].first

    UI.user_error!('Expo iOS workspace not found after expo prebuild + pod install.') unless workspace_path
    UI.user_error!('Expo iOS xcodeproj not found after expo prebuild.') unless project_path

    project_json = sh("xcodebuild -list -json -project '#{project_path}'", log: false)
    schemes = JSON.parse(project_json).dig('project', 'schemes') || []
    scheme = schemes.include?('SYNAP') ? 'SYNAP' : (schemes.reject { |s| s.downcase.include?('test') }.first || schemes.first)
    UI.user_error!("No Xcode scheme found in #{project_path}.") unless scheme
    UI.message("SYNAP_BUILD: Using scheme '#{scheme}' — workspace #{workspace_path}")

    # ── 7. Bump build number ──────────────────────────────────────────────────
    requested_build_number = ENV['IOS_BUILD_NUMBER'].to_s.strip
    build_number = requested_build_number.empty? ? (1000 + (ENV['GITHUB_RUN_NUMBER'] || '1').to_i).to_s : requested_build_number
    increment_build_number(build_number: build_number, xcodeproj: project_path)
    UI.message("SYNAP_BUILD: Build number set to #{build_number}")

    # ── 8. Force manual signing in the Xcode project ─────────────────────────
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  project_path,
      bundle_identifier:     'app.synap.fit',
      profile_name:          profile_name,
      code_sign_identity:    'iPhone Distribution',
      team_id:               ENV['APPLE_TEAM_ID'],
    )

    # ── 9. Build the IPA ──────────────────────────────────────────────────────
    # workspace: is required when CocoaPods is used — it links all pod targets.
    ipa_output_dir = File.join(REPO_ROOT, 'build')
    FileUtils.mkdir_p(ipa_output_dir)
    build_app(
      workspace:        workspace_path,
      scheme:           scheme,
      configuration:    'Release',
      sdk:              'iphoneos',
      export_method:    'app-store',
      output_directory: ipa_output_dir,
      output_name:      'SYNAP-Expo.ipa',
      xcargs:           "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
      export_options: {
        provisioningProfiles: { 'app.synap.fit' => profile_name },
        signingStyle:         'manual',
        teamID:               ENV['APPLE_TEAM_ID'],
      },
      clean: true,
    )

    # ── 10. Upload to TestFlight ──────────────────────────────────────────────
    upload_to_testflight(
      api_key:                           asc_api_key,
      ipa:                               File.join(ipa_output_dir, 'SYNAP-Expo.ipa'),
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
    )

    UI.message("✅ SYNAP_BUILD: build #{build_number} uploaded to TestFlight")
  end

end
