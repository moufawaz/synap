# Fastlane Fastfile — SYNAP
# ─────────────────────────────────────────────────────────────────────────────
# Lanes:
#   android beta   → build signed AAB → upload to Play Internal Track
#   ios beta       → build IPA → upload to TestFlight
#   ios certs      → sync/create App Store Distribution certs via match
#
# Run locally:
#   bundle exec fastlane android beta
#   bundle exec fastlane ios beta
#
# In CI the same commands are run — secrets come from env vars.
# ─────────────────────────────────────────────────────────────────────────────

default_platform(:android)

# ─────────────────────────────────────────────────────────────────────────────
# ANDROID
# ─────────────────────────────────────────────────────────────────────────────
platform :android do

  desc "Build a signed AAB and upload to Play Internal Track"
  lane :beta do
    # 1. Bump versionCode using the GITHUB_RUN_NUMBER env var if present,
    #    otherwise fall back to timestamp.
    version_code = (ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s).to_i

    # Patch versionCode directly — no plugin required
    sh("sed -i 's/versionCode [0-9]*/versionCode #{version_code}/' ../android/app/build.gradle")

    # 2. Build signed release AAB
    gradle(
      task:            'bundle',
      build_type:      'Release',
      project_dir:     'android/',
      print_command:   false,
      properties: {
        'android.injected.signing.store.file'     => ENV['ANDROID_KEYSTORE_PATH'],
        'android.injected.signing.store.password' => ENV['ANDROID_KEYSTORE_PASSWORD'],
        'android.injected.signing.key.alias'      => ENV['ANDROID_KEY_ALIAS'],
        'android.injected.signing.key.password'   => ENV['ANDROID_KEY_PASSWORD'],
      },
    )

    # 3. Upload to Play Internal Track
    supply(
      aab:             lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH],
      track:           'internal',
      package_name:    'app.synap.fit',
      json_key_data:   ENV['GOOGLE_PLAY_JSON_KEY'],
      skip_upload_apk: true,
      release_status:  'draft',  # change to 'completed' when ready to promote
    )

    # 4. Notify (optional — remove if not using Slack)
    if ENV['SLACK_WEBHOOK_URL']&.start_with?('https://')
      slack(
        message:     "✅ SYNAP Android #{version_code} uploaded to Play Internal Track",
        slack_url:   ENV['SLACK_WEBHOOK_URL'],
        success:     true,
      )
    end
  end

end

# ─────────────────────────────────────────────────────────────────────────────
# iOS  (requires macOS runner)
# ─────────────────────────────────────────────────────────────────────────────
platform :ios do

  # Build the API key object from individual env vars.
  # We use ASC_P8_KEY_PATH (not APP_STORE_CONNECT_API_KEY_PATH) so that
  # Fastlane does NOT auto-detect and try to JSON-parse the raw .p8 file.
  def asc_api_key
    app_store_connect_api_key(
      key_id:      ENV['APP_STORE_CONNECT_API_KEY_ID'],
      issuer_id:   ENV['APP_STORE_CONNECT_ISSUER_ID'],
      key_content: File.read(ENV['ASC_P8_KEY_PATH']),
    )
  end

  desc "Sync (or create) App Store Distribution certificates using match"
  lane :certs do
    match(
      type:                    'appstore',
      app_identifier:          'app.synap.fit',
      git_url:                 ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_TOKEN'],
      readonly:                is_ci,
      keychain_name:           'fastlane_match',
      keychain_password:       ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      api_key:                 asc_api_key,
      verbose:                 false,
    )
  end

  desc "Create certificates and profiles in match repo (run once, not in CI)"
  lane :certs_create do
    match(
      type:                    'appstore',
      app_identifier:          'app.synap.fit',
      git_url:                 ENV['MATCH_GIT_URL'],
      git_basic_authorization: ENV['MATCH_GIT_TOKEN'],
      readonly:                false,
      force:                   true,
      keychain_name:           'fastlane_match',
      keychain_password:       ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      api_key:                 asc_api_key,
    )
  end

  desc "Build IPA and upload to TestFlight"
  lane :beta do
    # 1. Create a fresh keychain and install certs
    create_keychain(
      name:            'fastlane_match',
      password:        ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      default_keychain: true,
      unlock:          true,
      timeout:         3600,
      lock_when_sleeps: false,
    )
    # The GitHub runner needs a signing identity with a private key. If the
    # match repo only has a certificate/profile pair without an importable
    # identity, readonly sync fails with "no local code signing identities".
    certs_create

    # 2. Bump build number
    build_number = (ENV['GITHUB_RUN_NUMBER'] || Time.now.to_i.to_s).to_i
    increment_build_number(
      build_number: build_number,
      xcodeproj:    'ios/App/App.xcodeproj',
    )

    # 3. Explicitly configure code signing in the Xcode project.
    # match with readonly:true installs certs but does NOT update project settings.
    # update_code_signing_settings forces the project to use the match profile.
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  'ios/App/App.xcodeproj',
      bundle_identifier:     'app.synap.fit',
      profile_name:          'match AppStore app.synap.fit',
      code_sign_identity:    'iPhone Distribution',
      team_id:               ENV['APPLE_TEAM_ID'],
    )

    # 5. Build IPA
    # sdk: 'iphoneos' tells xcodebuild to use the iOS device SDK directly.
    # This bypasses gym's automatic destination='generic/platform=iOS' which
    # fails on GitHub Actions macos-15 when Xcode 16 platform components are
    # listed as "not installed" (even though the SDK itself is available).
    build_app(
      project:           'ios/App/App.xcodeproj',
      scheme:            'App',
      configuration:     'Release',
      sdk:               'iphoneos',
      export_method:     'app-store',
      output_directory:  './build',
      output_name:       'SYNAP.ipa',
      xcargs:            "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='match AppStore app.synap.fit'",
      export_options: {
        provisioningProfiles: {
          'app.synap.fit' => 'match AppStore app.synap.fit',
        },
        signingStyle:    'manual',
        teamID:          ENV['APPLE_TEAM_ID'],
      },
      clean:             true,
    )

    # 6. Upload to TestFlight via App Store Connect API key (no password needed)
    upload_to_testflight(
      api_key:                           asc_api_key,
      ipa:                               './build/SYNAP.ipa',
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
    )

    # 5. Notify
    if ENV['SLACK_WEBHOOK_URL']&.start_with?('https://')
      slack(
        message:     "✅ SYNAP iOS build #{build_number} uploaded to TestFlight",
        slack_url:   ENV['SLACK_WEBHOOK_URL'],
        success:     true,
      )
    end
  end

  desc "Build Expo native IPA and upload to TestFlight"
  lane :expo_beta do
    require 'json'

    create_keychain(
      name:            'fastlane_match',
      password:        ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
      default_keychain: true,
      unlock:          true,
      timeout:         3600,
      lock_when_sleeps: false,
    )
    cert(
      development:       false,
      force:             true,
      api_key:           asc_api_key,
      keychain_path:     File.expand_path('~/Library/Keychains/fastlane_match-db'),
      keychain_password: ENV['MATCH_KEYCHAIN_PASSWORD'] || 'fastlane_match',
    )

    sigh(
      adhoc:          false,
      force:          true,
      app_identifier: 'app.synap.fit',
      api_key:        asc_api_key,
      output_path:    './build/profiles',
      filename:       'Synap_AppStore.mobileprovision',
    )

    profile_path = Actions.lane_context[SharedValues::SIGH_PROFILE_PATH]
    UI.user_error!("Provisioning profile was not created at #{profile_path}.") unless profile_path && File.exist?(profile_path)
    profile_xml = sh("security cms -D -i '#{profile_path}'", log: false)
    FileUtils.mkdir_p('./build/profiles')
    File.write('./build/profiles/Synap_AppStore.plist', profile_xml)
    profile_name = sh("/usr/libexec/PlistBuddy -c 'Print :Name' './build/profiles/Synap_AppStore.plist'", log: false).strip

    project_path = Dir['apps/mobile/ios/*.xcodeproj'].first
    UI.user_error!('Expo iOS project was not generated. Run expo prebuild first.') unless project_path

    project_json = sh("xcodebuild -list -json -project '#{project_path}'", log: false)
    schemes = JSON.parse(project_json).dig('project', 'schemes') || []
    scheme = schemes.include?('SYNAP') ? 'SYNAP' : schemes.first
    UI.user_error!("No Xcode scheme found in #{project_path}.") unless scheme

    requested_build_number = ENV['IOS_BUILD_NUMBER'].to_s.strip
    build_number = requested_build_number.empty? ? (1000 + (ENV['GITHUB_RUN_NUMBER'] || '1').to_i).to_s : requested_build_number
    increment_build_number(
      build_number: build_number,
      xcodeproj:    project_path,
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  project_path,
      bundle_identifier:     'app.synap.fit',
      profile_name:          profile_name,
      code_sign_identity:    'iPhone Distribution',
      team_id:               ENV['APPLE_TEAM_ID'],
    )

    build_app(
      project:           project_path,
      scheme:            scheme,
      configuration:     'Release',
      sdk:               'iphoneos',
      export_method:     'app-store',
      output_directory:  './build',
      output_name:       'SYNAP-Expo.ipa',
      xcargs:            "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']} CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{profile_name}'",
      export_options: {
        provisioningProfiles: {
          'app.synap.fit' => profile_name,
        },
        signingStyle:    'manual',
        teamID:          ENV['APPLE_TEAM_ID'],
      },
      clean:             true,
    )

    upload_to_testflight(
      api_key:                           asc_api_key,
      ipa:                               './build/SYNAP-Expo.ipa',
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
    )
  end

end
